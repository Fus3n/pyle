let os = import("os")

fn factorial(n) {
    let result = 1
    let i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

fn main() {
    let start = os.time()
    let i = 0
    while i < 100000 {
        factorial(15)
        i += 1
    }
    let end = os.time()
    printf("Finished benchmark.")
    printf("Time taken: {} seconds", end - start)
}

main()