{
    "comments": {
        "lineComment": {
            "comment": "#",
        }
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "onEnterRules": [
        {
            "beforeText": "^.*\\{\\s*$",
            "afterText": "^\\s*\\}",
            "action": {
                "indent": "indentOutdent"
            }
        },
        {
            "beforeText": "^.*\\{\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ]
}