{
  "scopeName": "source.pyle",
  "patterns": [
    {
      "name": "comment.line.number-sign.pyle",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.double.pyle",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.pyle",
          "match": "\\\\[ntr\\\\\"'0]"
        }
      ]
    },
    {
      "comment": "Function declarations with parameter highlighting: fn my_func(a, b)",
      "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "beginCaptures": {
        "1": {
          "name": "storage.type.function.pyle"
        },
        "2": {
          "name": "entity.name.function.pyle"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.parameters.end.pyle"
        }
      },
      "patterns": [
        {
          "name": "variable.parameter.function.pyle",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.parameters.pyle",
          "match": ","
        }
      ]
    },
    {
      "comment": "Struct declarations: struct Player",
      "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.pyle"
        },
        "2": {
          "name": "entity.name.type.struct.pyle"
        }
      }
    },
    {
      "name": "storage.type.pyle",
      "match": "\\b(let)\\b"
    },
    {
      "name": "keyword.control.pyle",
      "match": "\\b(if|else|elif|for|in|while|loop|return|break|yield|or|and|not|enum)\\b"
    },
    {
      "name": "variable.language.self.pyle",
      "match": "\\bself\\b"
    },
    {
      "name": "constant.language.pyle",
      "match": "\\b(true|false|none)\\b"
    },
    {
      "name": "support.function.builtin.pyle",
      "match": "\\b(print|printf|format|import|add_import_path|typeof|Coro)\\b"
    },
    {
      "comment": "Method/Property access: self.health (highlights 'health')",
      "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*\\b(?!\\s*\\()",
      "name": "variable.other.property.pyle"
    },
    {
      "comment": "Function & Method calls: my_func() or object.method()",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.call.pyle"
        }
      }
    },
    {
      "name": "keyword.operator.pyle",
      "match": "(\\+|\\-|\\*|/|%|==|!=|<=|>=|=|<|>|\\+=|\\-=|\\*=|/=|\\.\\.|=>)"
    },
    {
      "name": "constant.numeric.pyle",
      "match": "\\b(0x[0-9a-fA-F]+|\\d+(\\.\\d+)?)\\b"
    }
  ]
}